# Application
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# API
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/speech_jobs_backend

# Storage
STORAGE_ROOT=./storage
INPUT_STORAGE_DIR=./storage/inputs
ARTIFACT_STORAGE_DIR=./storage/artifacts

# Processing defaults
DEFAULT_PROFILE=balanced
DEVICE_PREFERENCE=auto

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_CLEANUP_EVERY_N_JOBS=10
WORKER_ID=local-worker-1

# Retention policy
INPUT_RETENTION_DAYS=7
ARTIFACT_RETENTION_DAYS=7
DELETE_INPUT_ON_SUCCESS=false
STORE_INTERMEDIATE_ARTIFACTS=false

# Upload limits
MAX_UPLOAD_SIZE_MB=200
ALLOWED_AUDIO_EXTENSIONS=m4a,mp3,wav,flac,ogg,opus

# External services
HUGGINGFACE_TOKEN=your_huggingface_token_here
